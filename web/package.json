{
  "name": "toby-bot-web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:e2e": "npm run test:e2e:build && playwright test",
    "test:e2e:build": "node src/test/e2e/build-fixtures.js",
    "lint:css": "stylelint \"src/main/resources/static/css/**/*.css\""
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/src/test/js/**/*.test.js"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended": "^14.0.1"
  }
}
